{
  "name": "felo-z/laravel-helper",
  "description": "Laravel helper",
  "type": "library",
  "keywords": [
    "laravel",
    "helper",
    "cache",
    "logs",
    "artisan"
  ],
  "homepage": "https://github.com/Felo-Z/laravel-helper",
  "license": "MIT",
  "authors": [
    {
      "name": "FeloZ",
      "email": "1538193053@qq.com"
    }
  ],
  "support": {
    "issues": "https://github.com/Felo-Z/laravel-helper/issues",
    "source": "https://github.com/Felo-Z/laravel-helper"
  },
  "require": {
    "php": "^8.4",
    "laravel/framework": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "FeloZ\\LaravelHelper\\": "src"
    },
    "files": [
      "src/Support/helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "jetbrains/phpstorm-attributes": "^1.0",
    "laravel/pint": "^1.24",
    "phpunit/phpunit": "^12.0",
    "orchestra/testbench": "^11.0",
    "phpstan/phpstan": "^2.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "FeloZ\\LaravelHelper\\HelperServiceProvider"
      ]
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.packagist.org"
    }
  ],
  "scripts": {
    "post-merge": "composer install",
    "check-style": "vendor/bin/pint --test",
    "fix-style": "vendor/bin/pint",
    "test": "phpunit --colors",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "psalm": "psalm --show-info=true --no-cache",
    "psalm-fix": "psalm --no-cache --alter --issues=MissingReturnType,MissingParamType"
  },
  "scripts-descriptions": {
    "test": "Run all tests.",
    "check-style": "Run style checks (only dry run - no fixing!).",
    "fix-style": "Run style checks and fix violations."
  },
  "config": {
    "allow-plugins": true,
    "minimum-stability": "dev",
    "prefer-stable": true
  }
}
